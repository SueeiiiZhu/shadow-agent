[Unit]
Description=Shadow Agent (Shadow Panel data plane / node core)
Documentation=https://github.com/SueeiiiZhu/shadow-agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
# Binary and config locations (adjust as needed).
ExecStart=/usr/local/bin/shadow-agent -config /etc/shadow-agent/config.json
Restart=on-failure
RestartSec=3s

# The agent needs to read/write generated kernel configs under DataDir and to
# spawn kernel binaries from KernelBinDir.
StateDirectory=shadow-agent
WorkingDirectory=/var/lib/shadow-agent

# Hardening (relax if a kernel needs extra capabilities, e.g. low ports).
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
NoNewPrivileges=true
ProtectSystem=full
ProtectHome=true
PrivateTmp=true
LimitNOFILE=1048576

[Install]
WantedBy=multi-user.target
